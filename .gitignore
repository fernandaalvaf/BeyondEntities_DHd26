# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual Environment
.venv/
venv/
ENV/
env/

# Configuration
# config.yaml ist jetzt OHNE Keys → darf ins Repo
# Secrets stehen nur in .env (wird nicht committed)
.env

# Output-Verzeichnisse (werden lokal generiert)
pipeline/output_json/*
!pipeline/output_json/.gitkeep

# CSV-Exports (werden lokal generiert)
pipeline/csv/*
!pipeline/csv/.gitkeep

# Logs
pipeline/logs/*
!pipeline/logs/.gitkeep

# Input-Daten (zu groß für Git)
pipeline/analyze/*
!pipeline/analyze/.gitkeep

# Examples (optional, falls zu groß)
pipeline/examples/*
!pipeline/examples/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
# docker/.env nicht mehr nötig → .env liegt im Root

# OS
.DS_Store
Thumbs.db
